{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "audit-assistant/knowledge-base/schema.json",
  "title": "Référentiel de questions ITGC — CDC section 11.1",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "domain", "theme", "question_text", "applicable_to", "depth_levels"],
    "additionalProperties": false,
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^(acces|changements|operations|continuite)_[0-9]{3}$"
      },
      "domain": {
        "type": "string",
        "enum": ["acces", "changements", "operations", "continuite"]
      },
      "theme": { "type": "string", "minLength": 1 },
      "question_text": { "type": "string", "minLength": 1 },
      "follow_up_questions": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 }
      },
      "applicable_to": {
        "type": "object",
        "required": ["app_types", "interlocutors", "mission_types"],
        "additionalProperties": false,
        "properties": {
          "app_types": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": ["erp", "middleware", "batch", "saas", "on_premise", "autre"]
            }
          },
          "interlocutors": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": ["dba", "infra", "rssi", "responsable_applicatif", "dsi", "autre"]
            }
          },
          "mission_types": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": ["audit_annuel", "controle_interne", "revue_ciblee", "autre"]
            }
          }
        }
      },
      "depth_levels": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "integer", "enum": [30, 45, 60, 90] }
      },
      "children": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["condition", "question_id"],
          "additionalProperties": false,
          "properties": {
            "condition": { "type": "string", "minLength": 1 },
            "question_id": { "type": "string" }
          }
        }
      }
    }
  }
}
